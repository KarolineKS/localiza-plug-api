{
  "name": "localizaplug-api",
  "version": "1.0.0",
  "description": "API REST do LocalizaPlug — localizador de eletropostos para carros elétricos em Pelotas/RS",
  "main": "api/index.ts",
  "scripts": {
    "dev": "vercel dev",
    "build": "prisma generate && tsc",
    "vercel-build": "prisma generate && tsc",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "start": "node dist/api/index.js"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@vercel/node": "^5.0.0",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
