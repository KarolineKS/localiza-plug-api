generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Station {
  id           String   @id @default(cuid())
  name         String
  lat          Float
  lng          Float
  address      String
  neighborhood String
  city         String   @default("Pelotas")
  state        String   @default("RS")
  plugs        Plug[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([city])
  @@map("stations")
}

model Plug {
  id            String    @id @default(cuid())
  stationId     String
  connectorType String
  powerKW       Int
  status        String
  pricePerKWh   Float
  priceType     String
  reservedUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([stationId])
  @@index([status])
  @@index([connectorType])
  @@map("plugs")
}
