generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StationStatus {
  DISPONIVEL
  OCUPADO
  EM_MANUTENCAO
  RESERVADO
}

enum StationConnector {
  CCS2
  TIPO_2
  CHADEMO
}

enum StationPrice {
  GRATUITO
  PAGO
}

model Station {
  id           String           @id @default(cuid())
  name         String
  lat          Float
  lng          Float
  address      String
  neighborhood String
  city         String           @default("Pelotas")
  state        String           @default("RS")
  status       StationStatus
  connector    StationConnector
  powerKW      Int
  price        StationPrice
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status])
  @@index([connector])
  @@index([city])
  @@map("stations")
}
