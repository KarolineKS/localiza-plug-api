meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@test.com",
    "password": "senha123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("token", res.body.data.token);
  }
}

docs {
  Faz login. Salva token em {{token}} automaticamente para as requests do Admin.
}
