meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "admin@test.com",
    "password": "senha123"
  }
}

script:post-response {
  if (res.status === 201 || res.status === 200) {
    bru.setEnvVar("token", res.body.data.token);
  }
}

docs {
  Cria usuário. Salva token em {{token}} automaticamente.
}
