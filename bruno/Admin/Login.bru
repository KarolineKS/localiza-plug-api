meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/admin/login
  body: json
  auth: none
}

body:json {
  {
    "password": "admin123"
  }
}

script:post-response {
  if (res.status === 200 && res.body.token) {
    bru.setEnvVar("token", res.body.token);
  }
}

docs {
  Login do admin com senha (validada contra ADMIN_PASSWORD bcrypt no .env).
  Salva o JWT em {{token}} automaticamente.
}
