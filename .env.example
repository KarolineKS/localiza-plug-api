# Connection string COM pooler (use essa em DATABASE_URL)
# Formato: postgresql://USER:PASS@ep-xxx-pooler.region.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://..."

# Connection string DIRETA (use essa em DIRECT_URL, só para migrations)
# Formato: postgresql://USER:PASS@ep-xxx.region.neon.tech/dbname?sslmode=require
DIRECT_URL="postgresql://..."

# Hash bcrypt da senha de admin
# Gere com: node -e "console.log(require('bcryptjs').hashSync('SUA_SENHA', 10))"
ADMIN_PASSWORD="$2a$10$..."

# Segredo para assinar JWTs (string aleatória longa)
# Gere com: openssl rand -base64 32
JWT_SECRET="troque-por-uma-string-aleatoria-longa"

# Duração do token de login (formato do jsonwebtoken: 1h, 24h, 7d, etc.)
JWT_EXPIRES_IN="24h"
